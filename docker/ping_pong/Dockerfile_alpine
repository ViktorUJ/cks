# Build on the native host arch and cross-compile to the target arch (no QEMU),
# so `go build` runs natively and uses all host CPUs.
FROM --platform=$BUILDPLATFORM golang:alpine AS builder
ARG TARGETOS
ARG TARGETARCH

RUN apk update && apk add --no-cache git
WORKDIR $GOPATH/src/mypackage/myapp/
COPY app/ .
RUN go mod tidy
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -ldflags="-w -s" -o app .

FROM alpine:3.22.1
RUN apk add --update --no-cache curl netcat-openbsd bash jq mysql-client bind-tools postgresql-client mongodb-tools
COPY --from=builder /go/src/mypackage/myapp/app app
ENTRYPOINT ["/app"]
